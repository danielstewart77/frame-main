# frame-main configuration. Copy to .env (mode 600) and fill in.
# Everything that differs between the offline box and the box wired to the
# proxy is here. See docs/go-live.md.

FRAME_HOST=127.0.0.1
FRAME_PORT=8500
FRAME_SERVER_URL=http://127.0.0.1:8500
FRAME_DEBUG=false

# --- sandbox --------------------------------------------------------------
# fake  : no Docker, synthetic harness stream (offline development)
# docker: real pristine containers
FRAME_PROVISIONER=fake
FRAME_SANDBOX_IMAGE=frame-main-sandbox:latest
FRAME_APP_PORT_MIN=9600
FRAME_APP_PORT_MAX=9699
FRAME_MAX_CONCURRENT=12
FRAME_IDLE_TIMEOUT_MINUTES=30
FRAME_TURN_TIMEOUT_SECONDS=1800

FRAME_DEFAULT_HARNESS=claude
FRAME_DEFAULT_MODEL=opus

# --- skills ---------------------------------------------------------------
# Agent skills shared read-only into every container. Set the two ADO repo URLs
# and the control plane clones/pulls them (admin "sync skills" button) into
# FRAME_SKILLS_ROOT using the host account's git credential — the PAT is set up
# once with `git config credential.helper` and never enters a container.
# <root>/claude-skills mounts at ~/.claude/skills, <root>/codex-skills at
# ~/.codex/skills. Leave the repos blank to run without shared skills.
FRAME_SKILLS_ROOT=./skills
FRAME_CLAUDE_SKILLS_REPO=
FRAME_CODEX_SKILLS_REPO=

# --- channel --------------------------------------------------------------
# The URL the container's stdio shim calls back on, so it is the host as seen
# from inside the sandbox, not the control plane's own bind address. The shim's
# bearer is no longer set here: one is minted per session at spawn, so a
# container can only speak for itself.
FRAME_CHANNEL_URL=http://host.docker.internal:8500
FRAME_CHANNEL_CONFIG=/opt/frame/mcp.json

# --- authentication -------------------------------------------------------
# The operator/registration credential. It mints and lists users, resolves a
# chat identity to an account, and can register further accounts once the box
# is claimed. Generate one (e.g. `openssl rand -base64 32`). Empty means no
# such principal exists and only console logins work.
FRAME_SERVICE_TOKEN=
# How long a console login stays valid before it must be re-entered (hours).
FRAME_AUTH_TOKEN_TTL_HOURS=720

# --- voice ----------------------------------------------------------------
# fake : offline round-trip stand-in
# azure: Azure Whisper STT + Azure neural TTS (needs VPN reachability)
FRAME_VOICE=fake
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=en-US-AndrewMultilingualNeural
AZURE_WHISPER_DEPLOYMENT=whisper

# --- proxy the harnesses reach the provider through -----------------------
# Sessions reach Claude and Codex through the UT System AI proxy. One base URL
# and one token serve both harnesses; the control plane maps them onto the env
# var names each harness reads (ANTHROPIC_* for claude, OPENAI_* for codex).
# The token is named for the proxy, not the provider, so it is not mistaken for
# an Anthropic key. Empty = harness calls the provider directly (offline
# development uses the fake provisioner, so neither is needed until
# FRAME_PROVISIONER=docker).
ANTHROPIC_BASE_URL=https://ulmaiproxy.utsystem.edu
ULMAIPROXY_AUTH_TOKEN=

# --- surfaces -------------------------------------------------------------
# Telegram is optional and per-user: each user pastes their own BotFather token
# on the console settings screen. There is no shared bot token. This tunes how
# often the in-process supervisor reconciles running bots against the table.
FRAME_TELEGRAM_RECONCILE_SECONDS=15
